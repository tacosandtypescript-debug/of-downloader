#!/data/data/com.termux/files/usr/bin/bash
set -u

APP_HOME="/root/.local/share/ofbackup"
HOST_APP_HOME="$HOME/.local/share/ofbackup"
HOST_CACHE="$HOME/.cache/ofbackup"
IMPORT_REQUEST_EXIT=42
APP_UPDATE_REQUEST_EXIT=43
SELECTED_TEMP=""
MAX_AUTH_SIZE=65536
UPDATE_STATUS="unknown"

cleanup_temp() {
    if [[ -n "$SELECTED_TEMP" ]]; then
        rm -f "$SELECTED_TEMP"
        SELECTED_TEMP=""
    fi
}

trap cleanup_temp EXIT
trap 'cleanup_temp; exit 130' INT TERM

run_ofbackup() {
    proot-distro login --shared-home ofbackup-debian -- \
        env "OFDOWNLOADER_UPDATE_STATUS=$UPDATE_STATUS" \
        "$APP_HOME/.venv/bin/python" "$APP_HOME/ofbackup_cli.py" "$@"
}

find_repo_dir() {
    local candidate
    for candidate in \
        "${OFDOWNLOADER_REPO:-}" \
        "$PWD" \
        "$HOME/of-downloader"; do
        if [[ -n "$candidate" && -d "$candidate/.git" ]]; then
            printf '%s' "$candidate"
            return 0
        fi
    done
    return 1
}

check_repository_update() {
    local repo
    repo="$(find_repo_dir)" || {
        printf 'repo-missing'
        return 0
    }
    if command -v timeout >/dev/null 2>&1; then
        timeout 6 git -C "$repo" fetch --quiet origin main </dev/null 2>/dev/null || {
            printf 'offline'
            return 0
        }
    elif ! git -C "$repo" fetch --quiet origin main </dev/null 2>/dev/null; then
        printf 'offline'
        return 0
    fi

    local current remote
    current="$(git -C "$repo" rev-parse HEAD 2>/dev/null)" || {
        printf 'error'
        return 0
    }
    remote="$(git -C "$repo" rev-parse origin/main 2>/dev/null)" || {
        printf 'error'
        return 0
    }
    if [[ "$current" == "$remote" ]]; then
        if [[ ! -f "$HOST_APP_HOME/ofbackup_cli.py" ]] || \
           ! cmp -s "$repo/ofbackup_cli.py" "$HOST_APP_HOME/ofbackup_cli.py"; then
            printf 'available'
        else
            printf 'current'
        fi
    elif git -C "$repo" merge-base --is-ancestor "$current" "$remote" 2>/dev/null; then
        printf 'available'
    else
        printf 'diverged'
    fi
}

update_application() {
    local repo
    repo="$(find_repo_dir)" || {
        echo "✗ No encuentro la carpeta del repositorio."
        echo "Clónalo de nuevo con: gh repo clone tacosandtypescript-debug/of-downloader"
        return 2
    }

    echo
    echo "Actualizando OF Downloader desde GitHub…"
    if ! git -C "$repo" pull --ff-only origin main; then
        echo "✗ No se pudo actualizar sin modificar tus archivos locales."
        echo "Revisa el mensaje de Git anterior y vuelve a intentarlo."
        return 2
    fi

    local requirements_changed=0
    if [[ ! -f "$HOST_APP_HOME/requirements-termux.txt" ]] || \
       ! cmp -s "$repo/requirements-termux.txt" "$HOST_APP_HOME/requirements-termux.txt"; then
        requirements_changed=1
    fi

    mkdir -p "$HOST_APP_HOME"
    install -m 600 "$repo/ofbackup_cli.py" "$HOST_APP_HOME/ofbackup_cli.py"
    install -m 600 "$repo/requirements-termux.txt" "$HOST_APP_HOME/requirements-termux.txt"
    install -m 755 "$repo/ofbackup" "$PREFIX/bin/of"
    install -m 755 "$repo/ofbackup" "$PREFIX/bin/ofbackup"

    if [[ "$requirements_changed" -eq 1 ]]; then
        echo "Actualizando componentes de Python…"
        if ! proot-distro login --shared-home ofbackup-debian -- \
            "$APP_HOME/.venv/bin/python" -m pip install --upgrade \
            -r "$APP_HOME/requirements-termux.txt"; then
            echo "✗ El código se actualizó, pero faltó actualizar componentes."
            echo "Ejecuta: bash $repo/instalar-termux.sh"
            return 2
        fi
    fi

    UPDATE_STATUS="current"
    echo "✓ OF Downloader actualizado. Reiniciando el menú…"
    return 0
}

run_selected_temp() {
    local selected="$1"
    local container_path
    container_path="/root/.cache/ofbackup/$(basename "$selected")"
    run_ofbackup importar-archivo "$container_path"
}

import_host_file() {
    local source="$1"
    if [[ ! -f "$source" ]]; then
        echo "✗ No encuentro el archivo: $source"
        return 2
    fi
    if [[ ! -s "$source" ]]; then
        echo "✗ El archivo está vacío. Vuelve a exportarlo desde la extensión."
        return 2
    fi
    local size
    size="$(wc -c <"$source")"
    if ((size > MAX_AUTH_SIZE)); then
        echo "✗ El archivo es demasiado grande para ser un archivo de acceso."
        return 2
    fi

    mkdir -p "$HOST_CACHE"
    local selected
    selected="$(mktemp "$HOST_CACHE/auth-import.XXXXXX.json")"
    SELECTED_TEMP="$selected"
    install -m 600 "$source" "$selected"
    run_selected_temp "$selected"
    local status=$?
    rm -f "$selected"
    SELECTED_TEMP=""
    return "$status"
}

latest_download_export() {
    local candidate=""
    local file
    shopt -s nullglob
    for file in "$HOME/storage/downloads"/OFBackup-auth*.json; do
        if [[ -s "$file" && ( -z "$candidate" || "$file" -nt "$candidate" ) ]]; then
            candidate="$file"
        fi
    done
    shopt -u nullglob
    printf '%s' "$candidate"
}

select_and_import() {
    if ! command -v termux-storage-get >/dev/null 2>&1; then
        echo "✗ Falta Termux:API. Instala el paquete con: pkg install termux-api"
        echo "También necesitas la aplicación Termux:API de la misma fuente que Termux."
        return 2
    fi

    mkdir -p "$HOST_CACHE"
    local selected
    selected="$(mktemp "$HOST_CACHE/auth-import.XXXXXX.json")"
    SELECTED_TEMP="$selected"
    chmod 600 "$selected"

    echo "Abriendo el selector de Android…"
    echo "Elige OFBackup-auth.json en Descargas."
    if ! termux-storage-get "$selected"; then
        rm -f "$selected"
        SELECTED_TEMP=""
        echo "✗ No se seleccionó ningún archivo o Termux:API no está disponible."
        echo "Comprueba que Termux y Termux:API procedan de la misma tienda."
        return 2
    fi

    if [[ ! -s "$selected" ]]; then
        rm -f "$selected"
        SELECTED_TEMP=""
        local downloaded
        downloaded="$(latest_download_export)"
        if [[ -n "$downloaded" ]]; then
            echo "El selector entregó un archivo vacío; usaré el archivo de Descargas."
            import_host_file "$downloaded"
            return $?
        fi
        echo "✗ Android entregó un archivo vacío."
        echo "Guarda OFBackup-auth.json en Descargas y ejecuta:"
        echo "  of importar ~/storage/downloads/OFBackup-auth.json"
        return 2
    fi

    run_selected_temp "$selected"
    local status=$?
    rm -f "$selected"
    SELECTED_TEMP=""
    return "$status"
}

if [[ "${1:-}" == "importar" ]]; then
    if [[ -n "${2:-}" ]]; then
        import_host_file "$2"
    else
        select_and_import
    fi
    exit $?
fi

case "${1:-menu}" in
    menu|actualizar-app|update-app)
        UPDATE_STATUS="$(check_repository_update)"
        ;;
esac

while true; do
    run_ofbackup "$@"
    status=$?
    if [[ "$status" -eq "$APP_UPDATE_REQUEST_EXIT" ]]; then
        if update_application; then
            set -- menu
            continue
        fi
        echo "Pulsa Enter para volver al menú…"
        read -r _ || true
        set -- menu
        continue
    fi
    if [[ "$status" -ne "$IMPORT_REQUEST_EXIT" ]]; then
        exit "$status"
    fi
    select_and_import
    status=$?
    if [[ "$status" -ne 0 ]]; then
        echo "Volviendo al menú…"
    fi
    set -- menu
done
