{
  "manifest_version": 3,
  "name": "OF Downloader Exporter",
  "version": "1.0.1",
  "description": "Exporta localmente los datos necesarios para conectar OF Downloader.",
  "icons": {
    "48": "icons/of-backup.svg",
    "96": "icons/of-backup.svg"
  },
  "permissions": [
    "activeTab",
    "cookies",
    "downloads"
  ],
  "host_permissions": [
    "https://onlyfans.com/*",
    "https://*.onlyfans.com/*"
  ],
  "action": {
    "default_title": "OF Downloader Exporter",
    "default_icon": "icons/of-backup.svg",
    "default_popup": "popup/exporter.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://onlyfans.com/*",
        "https://*.onlyfans.com/*"
      ],
      "js": [
        "content/session.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ofbackup-exporter@tacosandtypescript-debug.github.io",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
