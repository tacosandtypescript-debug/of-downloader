{
  "manifest_version": 3,
  "name": "OF Downloader Exporter",
  "version": "1.0.1",
  "minimum_chrome_version": "122",
  "description": "Exporta localmente los datos necesarios para conectar OF Downloader.",
  "icons": {
    "16": "icons/of-backup-16.png",
    "32": "icons/of-backup-32.png",
    "48": "icons/of-backup-48.png",
    "128": "icons/of-backup-128.png"
  },
  "permissions": [
    "activeTab",
    "cookies",
    "downloads"
  ],
  "host_permissions": [
    "https://onlyfans.com/*",
    "https://*.onlyfans.com/*"
  ],
  "action": {
    "default_title": "OF Downloader Exporter",
    "default_icon": {
      "16": "icons/of-backup-16.png",
      "32": "icons/of-backup-32.png"
    },
    "default_popup": "popup/exporter.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://onlyfans.com/*",
        "https://*.onlyfans.com/*"
      ],
      "js": [
        "content/session.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
